{
  "compilerOptions": {
    "target": "ES2020", // компиляция в современный js
    "useDefineForClassFields": true, // указываем как обрабатывать поля классов
    "lib": ["ES2020", "DOM", "DOM.Iterable"], // подключаем встроенные типы
    "module": "ESNext", // указываем формат работы с модулями
    "skipLibCheck": true, // не проверять типы из node modules
    "moduleResolution": "bundler", // делегируем работу с модулями vite
    "allowImportingTsExtensions": true, // разрешаем явный импорт файлов с расширением .tsx
    "resolveJsonModule": true, // разрешаем импортировать json файлы напрямую
    "isolatedModules": true, // независимая компиляция каждого файла
    "noEmit": true, // говорим TS только проверять типы
    "jsx": "react-jsx", // говорим как обрабатывать jsx
    "strict": true, // включение строгих проверок
    "ignoreDeprecations": "5.0",
    "baseUrl": ".", // папка для резолвов импортов
    "paths": {
      "@/*": ["./src/*"] // alias, который говорит TS при указании @ искать файлы в .src
    }
  },
  "include": ["src"], // проверки только внутри src
  "references": [{ "path": "./tsconfig.node.json" }]
}
