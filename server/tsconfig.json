{
  "compilerOptions": {
    "module": "commonjs", // тип импорта/экспорта
    "target": "ES2020", // стандарт javascript
    "rootDir": "./src", // указываем, где находятся исходники
    "outDir": "./dist", // куда класть скомпилированный js
    "strict": true, // режим строгой проверки
    "esModuleInterop": true, // упрощает импорт
    "resolveJsonModule": true // импорт json как модуль
  },
  "include": ["src/**/*"], // указываем какие файлы будет компилировать в js
  "exclude": ["node_modules", "dist"] // исключаем папки, которые не надо трогать
}
